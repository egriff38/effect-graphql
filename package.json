{
  "name": "effect-graphql-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter '*' test",
    "build": "bun --filter '*' build",
    "docgen": "bun --filter effect-graphql docgen",
    "dev": "bun --hot examples/dev-server/main.ts",
    "prototype": "bun prototype/main.ts",
    "release": "./release.sh"
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.74",
    "@types/node": "^25.9.3",
    "effect": "4.0.0-beta.74",
    "graphql": "^17.0.2",
    "typescript": "^5.6.0"
  }
}
