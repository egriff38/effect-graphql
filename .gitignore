node_modules
coverage
*.tgz

# Build outputs (per-package)
packages/*/dist
packages/*/coverage

# Docgen output (regenerated per build)
packages/core/docs/modules
packages/core/docs/examples
packages/core/docs/_config.yml
packages/core/docs/index.md
packages/core/docs/CNAME

# VitePress build cache + output
packages/docs/.vitepress/cache
packages/docs/.vitepress/dist

# Vale synced style packs (regenerated by `vale sync`); keep only AiSlop
# (hand-authored) and config/ (vocabularies) in version control.
styles/*
!styles/AiSlop
!styles/config

# Scratch typecheck dirs used by docs-writing agents (isolated Twoslash verification)
packages/docs/.check-errors
